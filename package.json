{
  "name": "xinghuo-ai",
  "version": "0.1.0",
  "private": true,
  "main": "apps/desktop/electron/main.js",
  "author": "MIAFOREVER",
  "description": "Minimal Electron compute dashboard with serverless-style auth backend.",
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:desktop dev:admin",
    "dev:api": "node packages/backend/src/server.js",
    "dev:desktop": "vite --host 127.0.0.1 --port 5173",
    "dev:admin": "vite --host 127.0.0.1 --port 5174 --config apps/admin/vite.config.js",
    "electron": "wait-on http://127.0.0.1:5173 && electron apps/desktop/electron/main.js",
    "start:desktop": "npm-run-all --parallel dev:api dev:desktop electron",
    "build": "npm-run-all build:desktop build:admin",
    "build:desktop": "vite build",
    "build:admin": "vite build --config apps/admin/vite.config.js",
    "pack:win": "electron-builder --win --dir",
    "dist:win": "electron-builder --win nsis",
    "lint": "node scripts/check-project.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "npm-run-all": "^4.1.5",
    "vite": "^7.0.6",
    "wait-on": "^8.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.xinghuo.ai",
    "productName": "星火 AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "apps/desktop/dist/**/*",
      "apps/desktop/electron/**/*",
      "packages/backend/**/*",
      "packages/miner-core/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
